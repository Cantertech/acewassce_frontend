# =========================================================================
# 🚀 ACEWASSCE MOCK PLATFORM - UNIFIED CONFIGURATION
# =========================================================================

# --- [1. AI & GRADING ENGINE] ---
# Get this from https://platform.openai.com/
OPENAI_API_KEY=your_openai_key_here

# --- [2. DATABASE & AUTH (SUPABASE)] ---
# Get these from your Supabase Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- [3. PAYMENTS (PAYSTACK)] ---
# Get this from https://dashboard.paystack.com/
PAYSTACK_SECRET_KEY=sk_live_xxxxxx_or_sk_test_xxxxxx

# --- [4. SMS & NOTIFICATIONS (HUBTEL)] ---
# Get these from your Hubtel Account Dashboard
HUBTEL_CLIENT_ID=your_hubtel_client_id
HUBTEL_CLIENT_SECRET=your_hubtel_client_secret
HUBTEL_SENDER_ID=AceWassce

# --- [5. BACKEND INFRASTRUCTURE (RAILWAY)] ---
# This will be your Railway provided public URL once you deploy
BACKEND_URL=http://localhost:8000
PORT=8000

# =========================================================================
# ⚠️ SECURITY REMINDER:
# Never commit your actual .env file to GitHub.
# Rename this file to .env and keep it local to your machine.
# =========================================================================
